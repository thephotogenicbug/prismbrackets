{
  "name": "prismbrackets",
  "displayName": "Prism Brackets - Rainbow Bracket Highlighter",
  "description": "Rainbow bracket highlighting with glow effect and matching bracket highlight for JavaScript, TypeScript, JSON and more in VS Code.",
  "version": "0.0.1",
  "publisher": "Naveendev",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "rainbow brackets",
    "bracket colorizer",
    "bracket highlighter",
    "color brackets",
    "nested brackets",
    "vscode brackets",
    "syntax highlighting",
    "code readability",
    "developer tools"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prismbrackets.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "icon": "assets/icon.png",
  "license": "MIT"
}
