{
  "name": "prismbrackets",
  "displayName": "Prism Brackets – Rainbow Bracket Highlighter & Scope Visualizer",
  "description": "Rainbow bracket highlighting with glow, theme-aware colors, multi-language support, and smart parsing for improved code readability in VS Code. Includes advanced scope highlighting with border glow and vertical guide lines, optimized for zero-lag performance and accurate detection that ignores strings and comments.",
  "version": "0.2.2",
  "publisher": "Naveendev",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "rainbow brackets",
    "bracket colorizer",
    "bracket highlighter",
    "color brackets vscode",
    "nested brackets",
    "bracket pair colorizer",
    "vscode bracket extension",
    "rainbow parentheses",
    "syntax highlighting",
    "code readability",
    "developer tools",
    "highlight brackets",
    "matching brackets",
    "code visualization",
    "programming productivity",
    "rainbow indentation",
    "bracket nesting",
    "code clarity",
    "vscode extension",
    "developer experience"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prismbrackets.toggleGlow",
        "title": "PrismBrackets: Toggle Glow"
      },
      {
        "command": "prismbrackets.toggleEnable",
        "title": "PrismBrackets: Enable/Disable"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thephotogenicbug/prismbrackets"
  }
}
