{
  "name": "prismbrackets",
  "displayName": "Prism Brackets - Rainbow Bracket Highlighter",
  "description": "Rainbow bracket highlighting with glow effect and matching bracket highlight for JavaScript, TypeScript, JSON and more in VS Code.",
  "version": "0.1.0",
  "publisher": "Naveendev",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "rainbow brackets",
    "bracket colorizer",
    "bracket highlighter",
    "color brackets",
    "nested brackets",
    "vscode brackets",
    "syntax highlighting",
    "code readability",
    "developer tools"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prismbrackets.toggleGlow",
        "title": "PrismBrackets: Toggle Glow"
      },
      {
        "command": "prismbrackets.toggleEnable",
        "title": "PrismBrackets: Enable/Disable"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thephotogenicbug/prismbrackets"
  }
}
